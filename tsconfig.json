{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["client/*"],
      "@server/*": ["server/*"]
    }
  },
  "include": ["server/**/*.js", "server/**/*.ts", "client/**/*.tsx"],
  "exclude": ["node_modules", "server/node_modules"]
}

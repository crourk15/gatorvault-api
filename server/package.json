{
  "name": "gatorvault-digest-server",
  "version": "0.1.0",
  "description": "Digest endpoint for GatorVault - accepts client digest and delivers via webhook/email",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:recruiting": "node scripts/seed-recruiting.js",
    "ingest:on3": "node scripts/run-on3-ingest.js",
    "ingest:on3:baseline": "node scripts/run-on3-ingest.js --baseline"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "express": "^4.18.2",
    "body-parser": "^1.20.2",
    "nodemailer": "^6.9.4",
    "node-fetch": "^2.6.7",
    "@sendgrid/mail": "^8.1.0",
    "dotenv": "^16.3.1"
  }
}

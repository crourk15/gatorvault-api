{
  "version": 1,
  "allowedBackgroundsByPage": {
    "/team": ["team-gradient", "team-dark", "team-surface"],
    "/film-room": ["film-slate", "film-dark"],
    "/": ["home-dark", "home-gradient"],
    "/latest": ["feed-dark", "feed-surface"],
    "/admin": ["admin-neutral"],
    "trial": ["trial-promo", "trial-gradient"]
  },
  "forbiddenBackgroundsCrossPage": {
    "trial-promo": ["/team", "/film-room", "/latest", "/admin"],
    "team-gradient": ["trial"],
    "film-slate": ["trial", "/team"]
  },
  "backgroundDetectors": {
    "trial-promo": [
      "trial-expired-ov",
      "trial-payment-banner",
      "id=\"pricing-sec\"",
      "pricing-features-film",
      "text-amber-300",
      "from-amber",
      "bg-amber"
    ],
    "trial-gradient": [
      "trial-expired",
      "gradient-to-r from-amber",
      "bg-gradient-to-br from-amber"
    ],
    "team-gradient": [
      "gv-team-page",
      "gv-team-era-card",
      "gv-team-overview",
      "gv-team-identity-card"
    ],
    "team-dark": [
      "gv-team-card-bg",
      "--gv-team-card-bg",
      "#121c2e"
    ],
    "team-surface": [
      "gv-team-section",
      "gv-mteam-tile-grid",
      "gv-team-ach-grid"
    ],
    "film-slate": [
      "vpane-highlights",
      "film-room-categories",
      "highlight-modal-ov"
    ],
    "film-dark": [
      "highlight-modal",
      "gv-film-source",
      "gv-verified-source"
    ],
    "home-dark": [
      "vpane-start",
      "vault-overlay",
      "gv-site-ticker"
    ],
    "home-gradient": [
      "bg-surface-700",
      "border-gator-blue"
    ],
    "feed-dark": [
      "vpane-beat",
      "live-feed",
      "gv-live"
    ],
    "feed-surface": [
      "feed-item",
      "latest-updates"
    ],
    "admin-neutral": [
      "hub-bg",
      "hub-panel",
      "admin-pin-ov"
    ]
  },
  "pageRegions": {
    "/team": {
      "regionIds": ["vpane-team", "vpane-mteam"],
      "requiredClasses": ["gv-team-page", "gv-team-section"],
      "desktopOnlyClasses": ["gv-team-overview-layout"],
      "forbiddenDetectors": ["trial-promo", "trial-gradient"],
      "cssFile": "/css/gv-team.css"
    },
    "/film-room": {
      "regionIds": ["vpane-highlights"],
      "requiredClasses": ["Film Room"],
      "forbiddenDetectors": ["trial-promo", "trial-gradient"],
      "requiredHooks": ["gvOpenVerifiedSource", "gv-film-source", "gvOpenFilmRoomHub", "film-room-hub-landing"]
    },
    "/": {
      "regionIds": ["vpane-start", "vpane-mhome"],
      "forbiddenDetectors": ["trial-promo"],
      "allowDetectors": ["home-dark", "home-gradient"]
    },
    "/latest": {
      "regionIds": ["vpane-beat"],
      "forbiddenDetectors": ["trial-promo", "team-gradient"],
      "allowDetectors": ["feed-dark", "feed-surface"]
    },
    "/admin": {
      "fetchPath": "/admin",
      "requiredClasses": ["admin-hub-core", "hub-sidebar"],
      "forbiddenDetectors": ["trial-promo", "team-gradient", "film-slate"],
      "allowDetectors": ["admin-neutral"]
    }
  },
  "componentVariants": {
    "team-overview": {
      "regionIds": ["vpane-team", "vpane-mteam"],
      "requiredMarkers": ["gv-team-overview-layout", "gv-team-overview-main"],
      "mobileMarkers": ["gv-mteam-tile-grid", "gv-team-section-title--accent"],
      "allowedVariantClasses": [
        "gv-team-era-card",
        "gv-team-ach-tile",
        "gv-team-identity-card",
        "gv-coach-card",
        "gv-team-section",
        "gv-team-overview-layout",
        "gv-team-page-hdr",
        "gv-hscroll-wrap",
        "gv-team-hscroll-wrap"
      ],
      "forbiddenClasses": [
        "pricing-sec",
        "trial-expired-ov",
        "reg-modal",
        "faq-btn",
        "card-h"
      ]
    },
    "film-source": {
      "globalHooks": [
        "gv-verified-source-modal",
        "gv-film-source",
        "gvOpenVerifiedSource"
      ],
      "allowedVariantClasses": [
        "highlight-modal-ov",
        "gv-verified-source-ov",
        "film-room"
      ],
      "forbiddenClasses": ["trial-expired-ov", "pricing-sec"]
    },
    "trial-page": {
      "regionMarkers": ["pricing-sec", "reg-modal", "trial-payment-banner"],
      "allowedVariantClasses": ["pricing-card", "faq-btn", "reg-modal", "trial-expired-ov"],
      "trialClassesForbiddenInTeamRegions": [
        "trial-expired-ov",
        "pricing-sec",
        "reg-modal",
        "faq-btn",
        "card-h",
        "text-amber-300",
        "from-amber",
        "bg-amber"
      ],
      "teamClassesForbiddenInTrialRegions": ["gv-team-overview-layout", "gv-team-page"]
    }
  },
  "cssTokenRules": {
    "team": {
      "file": "/css/gv-team.css",
      "requiredTokens": [
        "--gv-team-card-bg",
        "--gv-team-radius",
        "--gv-team-space-4",
        "--gv-team-title",
        "--gv-team-body"
      ],
      "forbiddenInTeamHtml": ["--hub-bg", "--hub-orange", "--hub-panel"]
    },
    "designSystemAliases": {
      "--bg-primary": "--gv-team-card-bg",
      "--bg-secondary": "--gv-team-card-border",
      "--brand-accent": "#fa4616",
      "--surface-card": "--gv-team-card-bg",
      "--surface-section": "--gv-team-space-6"
    }
  },
  "severityDefaults": {
    "team-overview-background": "high",
    "theme-token": "high",
    "component-variant": "medium",
    "css-link": "high",
    "cross-page-contamination": "critical"
  }
}

{
  "version": 2,
  "architecture": "react-vault",
  "allowedBackgroundsByPage": {
    "/vault/team": ["vault-dark", "vault-surface"],
    "/vault/film-room": ["vault-dark", "vault-surface"],
    "/vault/live-feed": ["vault-dark", "vault-surface"],
    "/": ["landing-dark", "landing-gradient"],
    "/admin": ["admin-neutral"]
  },
  "forbiddenBackgroundsCrossPage": {
    "trial-promo": ["/vault/team", "/vault/film-room", "/vault/live-feed", "/admin"],
    "monolith-vpane": ["/", "/vault"]
  },
  "backgroundDetectors": {
    "trial-promo": [
      "trial-expired-ov",
      "trial-payment-banner",
      "id=\"pricing-sec\"",
      "pricing-features-film"
    ],
    "monolith-vpane": [
      "vpane-start",
      "vpane-mteam",
      "vpane-highlights",
      "gvOpenTeamDetail",
      "openHighlightPlayer"
    ],
    "vault-dark": [
      "gv-vault-shell",
      "gv-vault-shell__main",
      "#060f1f"
    ],
    "vault-surface": [
      "gv-page-hero",
      "gv-hub-tabs",
      "gv-rh-grid"
    ],
    "landing-dark": [
      "data-testid=\"landing-page\"",
      "gv-landing-hero"
    ],
    "admin-neutral": [
      "hub-bg",
      "hub-panel",
      "admin-pin-ov"
    ]
  },
  "pageRegions": {
    "/vault/team": {
      "regionIds": ["vault-team"],
      "requiredClasses": ["gv-team-page", "gv-hub-tabs"],
      "requiredTestIds": ["vault-team"],
      "forbiddenDetectors": ["trial-promo", "monolith-vpane"],
      "cssFile": "/lib/vault-shell.css"
    },
    "/vault/film-room": {
      "regionIds": ["vault-film-room"],
      "requiredClasses": ["gv-film-room", "gv-film-hub-grid"],
      "requiredTestIds": ["vault-film-room"],
      "forbiddenDetectors": ["trial-promo", "monolith-vpane"]
    },
    "/vault/recruiting": {
      "regionIds": ["vault-recruiting"],
      "requiredClasses": ["gv-recruiting-hub", "gv-hub-tabs"],
      "requiredTestIds": ["vault-recruiting-hub"],
      "forbiddenDetectors": ["trial-promo", "monolith-vpane"]
    },
    "/vault/live-feed": {
      "regionIds": ["vault-live-feed"],
      "requiredClasses": ["gv-live-feed", "gv-live-ticker"],
      "requiredTestIds": ["vault-live-feed"],
      "forbiddenDetectors": ["trial-promo", "monolith-vpane"]
    },
    "/": {
      "regionIds": ["landing"],
      "requiredTestIds": ["landing-page"],
      "forbiddenDetectors": ["monolith-vpane"],
      "allowDetectors": ["landing-dark"]
    },
    "/admin": {
      "fetchPath": "/admin",
      "requiredClasses": ["admin-hub-core", "hub-sidebar"],
      "forbiddenDetectors": ["trial-promo", "monolith-vpane"],
      "allowDetectors": ["admin-neutral"]
    }
  },
  "componentVariants": {
    "vault-shell": {
      "requiredMarkers": ["gv-vault-shell", "gv-vault-shell__sidebar"],
      "mobileMarkers": ["gv-vault-bottom-nav"],
      "allowedVariantClasses": [
        "gv-vault-shell__nav-link",
        "gv-vault-bottom-nav__item",
        "gv-page-hero"
      ],
      "forbiddenClasses": [
        "vpane",
        "gv-bottom-nav",
        "highlight-card",
        "film-room-hub-landing"
      ]
    },
    "live-feed": {
      "requiredMarkers": ["gv-live-ticker", "gv-live-feed__tabs", "gv-live-feed__list"],
      "allowedVariantClasses": [
        "gv-live-feed__row",
        "gv-live-feed__chip",
        "gv-live-feed__podcast-card"
      ],
      "forbiddenClasses": ["vpane-beat", "live-feed-list"]
    }
  },
  "cssTokenRules": {
    "vault": {
      "file": "/lib/vault-shell.css",
      "requiredTokens": ["gv-vault-shell", "gv-page-title", "gv-hub-tab"],
      "forbiddenInVaultHtml": ["--hub-bg", "gv-team-modal-body"]
    }
  },
  "severityDefaults": {
    "monolith-contamination": "critical",
    "theme-token": "high",
    "component-variant": "medium",
    "css-link": "high",
    "cross-page-contamination": "critical"
  }
}

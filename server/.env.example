# GatorVault server — EmailJS + Beehiiv onboarding
PORT=3000
SITE_URL=https://gatorvaultinsider.com

# Beehiiv (optional — newsletter only; welcome email is sent via EmailJS on signup)
# BEEHIIV_API_KEY=
# BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx
# BEEHIIV_ONBOARDING_AUTOMATION_ID=aut_xxxxxxxx
SESSION_SECRET=replace-with-long-random-secret
EMAIL_PROVIDER=emailjs

# EmailJS — server REST uses Private Key Mode (accessToken only, no user_id in payload).
# New accounts use short keys like vBlY3DbhS-RZH4tCM — no prefix required.
# Enable: Account → Security → "Allow EmailJS API for non-browser applications"
EMAILJS_USER_ID=vBlY3DbhS-RZH4tCM
EMAILJS_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
EMAILJS_SERVICE_ID=service_ul7ju9p
EMAILJS_TEMPLATE_ID=template_okh1hj8
# Optional legacy — not used (single welcome template only)
# EMAILJS_ONBOARDING_TEMPLATE_ID=template_xxxxxxxx
EMAILJS_REPLY_TO=gatorvaultinsider@gmail.com

# Render deploy/sync (optional — for scripts/sync-render-env.js)
# RENDER_API_KEY=rnd_...

# Optional — PIN for /test-email.html and /api/test/* routes (defaults to admin PIN)
EMAIL_TEST_PIN=GV2026admin
RECRUITING_ADMIN_PIN=GV2026admin

# Recruiting live data (Phase 1+) — leave blank to use local JSON in data/recruiting/
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Recruiting pipeline monitoring (optional)
# MONITORING_SECRET=GV2026admin
# MONITORING_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# MONITORING_ALERT_EMAIL=you@example.com
# MONITORING_INGEST_STALE_MS=600000

# Phase 2 — On3 Florida ingest (optional)
# First run saves a baseline snapshot (no alerts). Then diffs fire commit/flip/decommit events.
ON3_INGEST_ENABLED=false
ON3_INGEST_INTERVAL_MS=120000
ON3_INGEST_BOOT_DELAY_MS=15000
ON3_CLASS_YEARS=2026,2027
ON3_ORG_SLUG=florida-gators

# GatorVault X AutoPoster — OAuth 1.0a posting as @gatorvault (NOT Bearer / OAuth 2.0)
# See docs/x-autoposter-setup.md
# X_OAUTH1_API_KEY=your_consumer_api_key
# (aliases also supported: TWITTER_API_KEY, TWITTER_API_SECRET, TWITTER_ACCESS_TOKEN, TWITTER_ACCESS_SECRET)
# X_OAUTH1_API_SECRET=your_consumer_api_secret
# X_OAUTH1_ACCESS_TOKEN=your_access_token
# X_OAUTH1_ACCESS_TOKEN_SECRET=your_access_token_secret
# X_AUTOPOST_ENABLED=false
# X_AUTOPOST_INTERVAL_MS=60000
# X_AUTOPOST_COOLDOWN_MS=2700000
# X_AUTOPOST_BURST_MS=420000
# X_AUTOPOST_NIGHT_MS=9000000
# X_AUTOPOST_BREAKING_BURST_MS=120000
# X_AUTOPOST_NIGHT_TZ=America/New_York
# X_AUTOPOST_ALLOW_PROMO=false
# X_AUTOPOST_REPLY_ENABLED=true
# X_AUTOPOST_BOOT_DELAY_MS=20000
# X_AUTOPOST_ACCOUNT=gatorvault
# X_AUTOPOST_PIN=GV2026admin
# X_AUTOPOST_CRON_SECRET=GV2026admin
# ON3_API_BASE=https://www.on3.com/sites/api/rdb/organizations
# INGEST_CRON_SECRET=GV2026admin

# GatorNation Live Dashboard (beat writers, podcasts, unified feed)
# REQUIRED on Render for Beat Writer Stream (Live Dashboard → Beat Writer Stream):
# 1. Render Dashboard → gatorvault-api → Environment
# 2. Add: X_BEARER_TOKEN = <raw Bearer Token from developer.x.com — use exactly as provided>
# 3. Save and redeploy — beat feed auto-refreshes every 3 minutes
# X_BEARER_TOKEN=your_twitter_api_v2_bearer_token
# NITTER_BASES=https://nitter.poast.org,https://nitter.privacydev.net
# LIVE_POLL_INTERVAL_MS=180000
# LIVE_POLL_BOOT_DELAY_MS=20000
# LIVE_CRON_SECRET=GV2026admin
# LIVE_ADMIN_PIN=GV2026admin

# Highlight + Interview ingestion pipeline (see docs/media-ingest-setup.md)
# Requires ffmpeg on PATH for processing. Inbox sources work without API keys.
# MEDIA_INGEST_ENABLED=false
# MEDIA_INGEST_INTERVAL_MS=900000
# MEDIA_INGEST_BOOT_DELAY_MS=45000
# MEDIA_INGEST_BATCH_LIMIT=5
# MEDIA_INGEST_PIN=GV2026admin
# MEDIA_CDN_BASE=https://gatorvault-api.onrender.com

# Optional
DIGEST_TOKEN=
DEFAULT_WEBHOOK=

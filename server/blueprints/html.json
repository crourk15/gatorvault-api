    "gvOpenTeamDetail": {
      "marker": "gvOpenTeamDetail",
      "description": "Team detail modal script hook",
      "requiredHooks": ["gv-team-mobile.js"],
      "expectedLocation": {
        "file": "index.html",
        "before": "</body>",
        "description": "Deferred script before </body>"
      },
      "acceptPatterns": ["gv-team-mobile.js", "gvOpenTeamDetail"],
      "snippet": "<script src=\"/js/gv-team-mobile.js?v=team-v3\" defer></script>"
    },
    "gvOpenVerifiedSource": {
      "marker": "gvOpenVerifiedSource",

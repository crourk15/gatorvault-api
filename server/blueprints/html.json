    "gv-team-overview-layout",
    "gv-coaching-staff",
    "gv-section-identity",
    "gv-section-recruiting",
    "gv-section-portal",
    "gv-section-news",
    "gv-section-film",
    "war-room-panel",
    "gvOpenTeamDetail",
    "film-room-hub-landing"

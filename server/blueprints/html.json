    "gv-section-news": {
      "id": "gv-section-news",
      "marker": "gv-section-news",
      "description": "Latest Updates / news feed section",
      "requiredHooks": ["gv-section-news", "vpane-live"],
      "expectedLocation": {
        "regionId": "vpane-live",
        "inside": "#vpane-live",
        "description": "Live feed tab pane"
      },
      "acceptPatterns": [
        "id=\"gv-section-news\"",
        "id=\"vpane-live\"",
        "data-gv-section=\"news\"",
        "data-gv-autoposter-zone=\"news\""
      ],
      "snippet": "<div id=\"gv-section-news\" class=\"gv-section-news\" data-gv-section=\"news\" data-gv-autoposter-zone=\"news\"></div>"

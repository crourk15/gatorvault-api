      "requiredHooks": ["gv-section-identity", "gv-team-identity"],
      "expectedLocation": {
        "regionId": "vpane-team",
        "inside": "#vpane-team",
        "description": "Inside team overview layout, Team Identity column"
      },
      "acceptPatterns": [
        "id=\"gv-section-identity\"",
        "id=\"gv-team-identity-slot\"",
        "id=\"gv-team-identity-banner\"",
        "Team Identity</h3>"
      ],
      "snippet": "<section id=\"gv-section-identity\" class=\"gv-team-section gv-team-identity-banner\" data-gv-section=\"identity\" aria-label=\"Team Identity\">\n  <div id=\"gv-team-identity-banner\" class=\"gv-team-identity-inner\"></div>\n</section>"
    },
